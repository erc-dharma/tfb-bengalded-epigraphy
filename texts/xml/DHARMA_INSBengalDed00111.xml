<p><milestone type="pagelike" unit="zone" n="A"/><label xml:lang="eng">Around the top of the stele</label>
<hi rend="check"><lb n="A1"/><lg n="1" met="āryā">
<l n="ab">ye dharmmā hetuprabhavā hetuṁ teṣāṁ tathāgato hy avadat</l> 
<l n="cd">teṣāṁ ca yo nirodha Evaṁvādī mahāśramaṇaḥ <g ref="sym:doubleBar" type="punctuation">.</g></l>
</lg></hi><!-- reading of stanza still to be checked against photos -->
<milestone type="pagelike" unit="zone" n="B"/><label xml:lang="eng">On the pedestal</label>
<lb n="B1"/><g ref="sym:spiral-left" type="symbol">*</g> <abbr>samvaT</abbr> <num value="4">4</num> caitra-<abbr>śudi</abbr> <num value="10"><g type="numeral">10</g></num> śrī-mah<choice><sic>i</sic><corr>e</corr></choice>ndrapāladeva-rājye saindhavā<hi rend="check">nāṁ</hi> 
<lb n="B2"/><hi rend="check"><unclear>dā</unclear>n<choice><sic>a</sic><corr>ā</corr></choice>rthe</hi> kumārabhaṭṭeṇa deva<surplus>d</surplus>dharmma<supplied reason="omitted">ḥ</supplied> pratipād<choice><sic>ī</sic><corr>i</corr></choice>taḥ <g ref="sym:bar" type="punctuation">.</g></p>
